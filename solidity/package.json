{
  "name": "leanimt-plus.sol",
  "description": "LeanIMT+ Solidity library: an Incremental Merkle Tree with membership and non-membership proofs.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:report-gas": "REPORT_GAS=true hardhat test",
    "test:coverage": "hardhat coverage",
    "lint": "solhint 'contracts/**/*.sol'",
    "slither": "slither . --include-paths contracts --exclude-dependencies --ignore-compile",
    "prettier": "prettier -c .",
    "prettier:write": "prettier -w ."
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.11",
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.6",
    "@nomicfoundation/hardhat-keystore": "^3.0.12",
    "@nomicfoundation/hardhat-mocha": "^3.0.21",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.11",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-typechain": "^3.1.1",
    "@nomicfoundation/hardhat-verify": "^3.0.21",
    "@nomicfoundation/ignition-core": "^3.1.8",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "chai": "^6.2.2",
    "ethers": "^6.17.0",
    "hardhat": "^3.9.1",
    "mocha": "^11.7.6",
    "poseidon-lite": "^0.3.0",
    "prettier": "^3.9.5",
    "solhint": "^6.2.3",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "poseidon-solidity": "0.0.5"
  },
  "packageManager": "yarn@4.17.1"
}
